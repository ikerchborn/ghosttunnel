# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/

# Build tools
*.spec

# Testing & audit output
.pytest_cache/
.coverage
htmlcov/
.tox/
bandit-report.txt
bandit-report.json

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Security-sensitive files — NEVER commit these
# Local config with sensitive data (VPN endpoints, custom IPs, etc.)
/etc/ghosttunnel/config.json
config.local.json
*.local.json

# Runtime state — generated at runtime, not source
# (Important! Ignoring status and locks to prevent leaks on GitHub)
/run/
*.pid
PANIC.lock
status.json
.status-*.tmp
.cfg-*.tmp
*.lock

# Private keys or credentials that might be added accidentally
*.key
*.pem
*.p12
*.pfx
*.crt
*.ovpn
*.conf

# Compiled nftables rules with local IPs (if ever generated)
*.rules.local

# Log files and crash dumps
*.log
*.core
*.dump
*.crash
nohup.out

# Local environmental variables & secrets
.env
.env.*
secrets/
.secret*

# Temp files & backups
*.bak
*.swp
*.tmp
*~
*.orig

# Additional Security / Audit Output
.mypy_cache/
.ruff_cache/
*.sarif
bandit-report.*
trufflehog-report.*
